{
  "name": "agent-repo-kit",
  "version": "0.1.0",
  "description": "Score and fix GitHub repos for AI coding agents.",
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "adapters:check": "node ./scripts/render-adapters.mjs --check",
    "adapters:render": "node ./scripts/render-adapters.mjs",
    "audit:pack": "node ./scripts/audit-pack.mjs",
    "fix": "node ./scripts/agent-repo-fix.mjs",
    "report": "node ./scripts/agent-repo-report.mjs",
    "test": "node --test ./tests/*.test.mjs"
  },
  "files": [
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "REVIEW.md",
    ".cursor",
    "adapters",
    "docs",
    ".mcp.json.example",
    ".claude",
    ".github",
    "scripts"
  ],
  "keywords": [
    "ai-agents",
    "ai-coding",
    "codex",
    "claude-code",
    "repo-readiness",
    "agent-ready"
  ],
  "license": "MIT"
}
