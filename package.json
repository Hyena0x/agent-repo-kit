{
  "name": "repo-guard-starter",
  "version": "0.1.0",
  "description": "Claude Code-first repo guardrails and a publish-time release guard for AI coding repos.",
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "adapters:check": "node ./scripts/render-adapters.mjs --check",
    "adapters:render": "node ./scripts/render-adapters.mjs",
    "audit:pack": "node ./scripts/audit-pack.mjs",
    "test": "node --test ./tests/*.test.mjs"
  },
  "files": [
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "REVIEW.md",
    ".cursor",
    "adapters",
    "docs",
    ".mcp.json.example",
    ".claude",
    ".github",
    "scripts"
  ],
  "keywords": [
    "claude-code",
    "ai-coding",
    "release-guard",
    "npm-pack",
    "devsecops"
  ],
  "license": "MIT"
}
